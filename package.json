{
  "name": "piano-tutor",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "web": "node node_modules/expo/bin/cli start --web",
    "build": "npm run export:web",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "export:web": "node node_modules/expo/bin/cli export --platform web && node scripts/prepare-static-routes.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.29",
    "expo-router": "^6.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
